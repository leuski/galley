/* Description for the Markdown UTI declared in Info.plist. The
   key is the UTI itself; macOS resolves UTTypeDescription per
   locale via this lookup. */
"net.daringfireball.markdown" = "Markdown Document";

/* Human-readable copyright shown in the About box and Finder's
   Get Info pane. Localized here so other regions can override
   the wording (e.g. "Tous droits réservés"). */
"NSHumanReadableCopyright" = "Copyright © 2026 Anton Leuski. All rights reserved.";
