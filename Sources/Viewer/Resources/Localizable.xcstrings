    "Adds a Format menu section that lets each window pin its own Markdown processor or template, overriding the global selection." : {
      "comment" : "A description of the \"Allow per-window processor and template overrides\" checkbox.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавляет в меню «Формат» раздел, позволяющий каждому окну закрепить собственный обработчик Markdown или шаблон, переопределяя глобальный выбор."
          }
        }
      }
    },
    "Adds a thin bar at the bottom of each document window with word count, character count, and estimated reading time." : {
      "comment" : "A description of the status bar.",
      "isCommentAutoGenerated" : true
    },
